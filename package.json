{
  "name": "cardwall",
  "version": "0.1.0",
  "description": "Browser-only Jira card wall for offline planning",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "node --test 'test/**/*.test.js'",
    "test:e2e": "node --test 'e2e/**/*.test.js'",
    "typecheck": "tsc -p jsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "dupes": "jscpd src app.js test",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run dupes && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@preact/signals": "2.0.1",
    "@types/papaparse": "^5.5.2",
    "@types/sortablejs": "^1.15.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^17.6.0",
    "htm": "3.1.1",
    "jscpd": "^4.2.5",
    "papaparse": "5.4.1",
    "preact": "10.26.4",
    "prettier": "^3.8.4",
    "puppeteer-core": "^25.1.0",
    "sortablejs": "^1.15.7",
    "typescript": "^5.9.3"
  }
}
